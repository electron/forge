{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "packages/api/core",
    "packages/maker/*",
    "packages/plugin/*",
    "packages/publisher/*",
    "packages/utils/types"
  ],
  "externalSymbolLinkMappings": {
    "listr2": {
      "ListrTask": "https://listr2.kilic.dev/api/listr2/interfaces/ListrTask.html"
    }
  },
  "packageOptions": {
    "excludeExternals": true
  }
}
